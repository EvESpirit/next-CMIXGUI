<Page
    x:Class="NextCmixGui.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    AllowDrop="True"
    DragOver="OnDragOver"
    Drop="OnDrop"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <Grid Padding="20" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="15">
                
                <Grid ColumnSpacing="10" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock x:Name="lblInput" Text="Select a file or folder to compress" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
                    <TextBox x:Name="txtInput" TextChanged="OnInputPathChanged" Grid.Row="0" Grid.Column="1"/>
                    <Button x:Name="btnBrowseInput" Content="..." Click="OnBrowseInput" Grid.Row="0" Grid.Column="2"/>

                    <TextBlock x:Name="lblOutput" Text="Select an output file location" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0"/>
                    <TextBox x:Name="txtOutput" Grid.Row="1" Grid.Column="1"/>
                    <Button x:Name="btnBrowseOutput" Content="..." Click="OnBrowseOutput" Grid.Row="1" Grid.Column="2"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock x:Name="lblVersion" Text="CMIX Version:" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbVersion" Width="200" SelectionChanged="OnVersionChanged"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="lblAction" Text="Action:" VerticalAlignment="Center"/>
                            <RadioButton x:Name="radCompress" Content="Compress" GroupName="Action" IsChecked="True" Checked="OnActionChanged"/>
                            <RadioButton x:Name="radExtract" Content="Extract" GroupName="Action" Checked="OnActionChanged"/>
                            <RadioButton x:Name="radPreprocess" Content="Preprocess" GroupName="Action" Checked="OnActionChanged"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <CheckBox x:Name="chkUseDict" Content="Use english.dic" Checked="OnOptionsChanged" Unchecked="OnOptionsChanged"/>
                            <CheckBox x:Name="chkShowCmd" Content="Show CMD Window" Checked="OnOptionsChanged" Unchecked="OnOptionsChanged"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                        <TextBlock x:Name="lblLanguage" Text="Language:" VerticalAlignment="Center"/>
                        <RadioButton x:Name="radLangEn" Content="English" GroupName="Lang" IsChecked="True" Checked="OnLanguageChanged"/>
                        <RadioButton x:Name="radLangEs" Content="Spanish" GroupName="Lang" Checked="OnLanguageChanged"/>
                    </StackPanel>
                </Grid>
                
            </StackPanel>

            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="20">
                <Grid>
                    <TextBlock x:Name="lblPlaceholder" Text="Select a file and click Start to begin" FontSize="24" FontStyle="Italic" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Grid x:Name="gridProgress" Visibility="Collapsed" RowSpacing="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="INPUT" FontWeight="Bold" FontSize="14"/>
                                <TextBlock x:Name="lblInputName" Text="Name: -" TextWrapping="Wrap"/>
                                <TextBlock x:Name="lblInputPath" Text="Path: -" TextWrapping="Wrap" Foreground="Gray"/>
                                <TextBlock x:Name="lblInputSize" Text="Size: -"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="OUTPUT" FontWeight="Bold" FontSize="14"/>
                                <TextBlock x:Name="lblOutputName" Text="Name: -" TextWrapping="Wrap"/>
                                <TextBlock x:Name="lblOutputPath" Text="Path: -" TextWrapping="Wrap" Foreground="Gray"/>
                                <TextBlock x:Name="lblOutputSize" Text="Size: -"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="5">
                            <Grid>
                                <TextBlock Text="PRETRAINING" FontWeight="Bold" FontSize="16" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="lblPretrainPercent" Text="0.00%" FontSize="14" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar x:Name="barPretrain" Minimum="0" Maximum="100" Value="0" Height="25"/>
                            <TextBlock x:Name="lblPretrainStats" Text="" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Spacing="5">
                            <Grid>
                                <TextBlock Text="PROGRESS" FontWeight="Bold" FontSize="16" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="lblMainPercent" Text="0.00%" FontSize="14" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar x:Name="barMain" Minimum="0" Maximum="100" Value="0" Height="25"/>
                            <TextBlock x:Name="lblMainStats" Text="" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" HorizontalAlignment="Center" Spacing="10">
                            <TextBlock x:Name="lblRatio" FontSize="24" FontWeight="Bold" Foreground="#2CA02C" HorizontalAlignment="Center" Visibility="Collapsed"/>
                            <Border x:Name="borderCancelled" Background="#D62728" HorizontalAlignment="Center" Visibility="Collapsed" Padding="10" CornerRadius="5">
                                <TextBlock x:Name="lblCancelled" Text="TASK CANCELLED" FontSize="20" FontWeight="Bold" Foreground="White" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="btnStart" Content="Start" FontSize="16" FontWeight="Bold" Height="40" Click="OnStartClicked"/>
                    <Button x:Name="btnCancel" Content="Cancel" FontSize="16" FontWeight="Bold" Height="40" Background="#D62728" Foreground="White" IsEnabled="False" Click="OnCancelClicked"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="GUI by EvESpirit | cmix by Byron Knoll" Foreground="#6495ED" FontStyle="Italic"/>
                </StackPanel>
            </Grid>

        </Grid>
    </ScrollViewer>
</Page>
